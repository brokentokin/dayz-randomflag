<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<types>
    <!--
        This example is based on the Chernarus and Livonia economies.
        Review every value against your server's economy and preferences before
        using it.

        To replace existing flag spawns, set nominal and min to 0 on every flag
        economy entry you want to replace. Otherwise, Tokin_RandomFlag will be
        added on top of those existing flag spawns.
    -->
    <type name="Tokin_RandomFlag">
        <nominal>42</nominal>
        <lifetime>14400</lifetime>
        <restock>0</restock>
        <min>21</min>
        <quantmin>-1</quantmin>
        <quantmax>-1</quantmax>
        <cost>100</cost>
        <flags count_in_cargo="1" count_in_hoarder="1" count_in_map="1" count_in_player="1" crafted="0" deloot="0"/>
        <category name="tools"/>
        <usage name="Office"/>
        <usage name="School"/>
    </type>
</types>
