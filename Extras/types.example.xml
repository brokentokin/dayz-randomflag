<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<types>
    <!--
        This entry pools the current vanilla flag economy into Tokin_RandomFlag.

        ChernarusPlus and Livonia (Enoch): nominal 42, min 21
        Sakhal:                         nominal 38, min 18

        The entry below defaults to the ChernarusPlus/Livonia totals. On Sakhal,
        change only nominal to 38 and min to 18.

        Namalsk uses separate regular and hardcore mission economies. Do not use
        these totals there without reviewing the Namalsk section of the README.

        Before enabling this entry, set nominal and min to 0 on every vanilla
        Flag_* entry in the mission economy. Otherwise Tokin_RandomFlag will be
        added on top of the existing vanilla flag spawns.

        Values audited against BohemiaInteractive/DayZ-Central-Economy commit
        8e769861441f19c32d30ba0d9a074e15b740d917 (DayZ 1.29).
    -->
    <type name="Tokin_RandomFlag">
        <nominal>42</nominal>
        <lifetime>14400</lifetime>
        <restock>0</restock>
        <min>21</min>
        <quantmin>-1</quantmin>
        <quantmax>-1</quantmax>
        <cost>100</cost>
        <flags count_in_cargo="1" count_in_hoarder="1" count_in_map="1" count_in_player="1" crafted="0" deloot="0"/>
        <category name="tools"/>
        <usage name="Office"/>
        <usage name="School"/>
    </type>
</types>
